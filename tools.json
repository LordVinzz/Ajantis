            "content": {
              "description": "Text content of the message to inject as a user turn.",
              "type": "string"
            },
            "attachments": {
              "description": "Optional file paths or data blobs to include alongside the message.",
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "await_reply": {
              "description": "If true, block until the agent produces a response and return it inline. If false, return immediately and poll with get_agent_state. Defaults to true.",
              "type": "boolean"
            },
            "timeout_ms": {
              "description": "Maximum milliseconds to wait when await_reply is true before returning a timeout error.",
              "minimum": 100,
              "type": "integer"
