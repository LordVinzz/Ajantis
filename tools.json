    {
      "function": {
        "description": "Spawn a new LLM subagent with a defined role, model, and system prompt. Spawned workers can use their allowed tools and self-message for short internal reasoning loops, but only managers can delegate across agents.",
        "name": "spawn_agent",
        "parameters": {
          "additionalProperties": false,
          "properties": {
            "role": {
              "description": "Short label for this agent's responsibility (e.g. 'coder', 'critic', 'planner').",
              "type": "string"
            },
            "system_prompt": {
              "description": "Full system-level instruction that defines the agent's persona, constraints, and objectives.",
              "type": "string"
            },
            "model": {
              "description": "Local LM Studio model key to use for this agent. It must already exist on this computer; guessed or remote-only model names are rejected. Defaults to the caller's own model if omitted.",
              "type": "string"
            },
            "context_limit": {
              "description": "Maximum token budget for this agent's context window. Omit to use the model default.",
              "minimum": 1024,
              "type": "integer"
            },
            "tools": {
              "description": "List of tool names the agent is allowed to call. Omit to give the worker the default non-manager tool set.",
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "metadata": {
              "description": "Arbitrary key-value pairs to attach to the agent for routing or bookkeeping.",
              "type": "object"
            }
          },
          "required": [
            "role",
            "system_prompt"
          ],
          "type": "object"
        }
      },
      "type": "function"
    },
    {
      "function": {
        "description": "Send a user-role message to a specific agent and optionally wait for its response. Managers can delegate to any agent; non-managers may only message themselves.",
        "name": "send_message",
        "parameters": {
          "additionalProperties": false,
          "properties": {
            "agent_id": {
              "description": "ID of the target agent returned by spawn_agent.",
              "type": "string"
